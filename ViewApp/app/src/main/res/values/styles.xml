<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Slop" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="colorPrimary">@color/surface</item>
        <item name="colorPrimaryDark">@color/bg</item>
        <item name="colorAccent">@color/neon</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:textColorSecondary">@color/text_dim</item>
        <item name="android:colorEdgeEffect">@color/neon</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
    </style>

    <!-- translucent pill controls overlaid on the video -->
    <style name="ControlButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:background">@drawable/bg_pill</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:minWidth">52dp</item>
        <item name="android:minHeight">42dp</item>
        <item name="android:paddingHorizontal">14dp</item>
    </style>
</resources>
