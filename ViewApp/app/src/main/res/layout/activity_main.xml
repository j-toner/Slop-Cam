<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000">

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/webrtcView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView android:id="@+id/tvStatus"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|start" android:layout_margin="14dp"
        android:paddingHorizontal="12dp" android:paddingVertical="6dp"
        android:background="@drawable/bg_chip"
        android:text="Disconnected" android:textColor="@color/text_dim"
        android:textSize="12sp" />

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end" android:layout_margin="12dp"
        android:orientation="horizontal">

        <ToggleButton android:id="@+id/btnFlashlight"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/toggle_text"
            android:textOn="Torch" android:textOff="Torch" />

        <Button android:id="@+id/btnPtt"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="PTT" />

        <Button android:id="@+id/btnSnap"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="📷" />

        <Button android:id="@+id/btnSnapshots"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Snaps" />

        <Button android:id="@+id/btnSettings"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="⚙" />
    </LinearLayout>
</FrameLayout>
