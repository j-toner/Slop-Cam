<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000">

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/webrtcView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|start" android:layout_margin="14dp"
        android:gravity="center_vertical" android:orientation="horizontal">

        <TextView android:id="@+id/tvStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:paddingHorizontal="12dp" android:paddingVertical="6dp"
            android:background="@drawable/bg_chip"
            android:text="Disconnected" android:textColor="@color/text_dim"
            android:textSize="12sp" />

        <LinearLayout android:id="@+id/recChip"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:paddingHorizontal="10dp" android:paddingVertical="6dp"
            android:background="@drawable/bg_chip"
            android:gravity="center_vertical" android:orientation="horizontal"
            android:visibility="gone">

            <View android:id="@+id/recDot"
                android:layout_width="14dp" android:layout_height="14dp"
                android:background="@drawable/rec_dot" />

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="REC" android:textColor="#FF1744"
                android:textSize="12sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- motion state: dim "MOTION" while detection is armed, pulsing
             dot + "MOTION REC" while the server's motion window records -->
        <LinearLayout android:id="@+id/motionChip"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:paddingHorizontal="10dp" android:paddingVertical="6dp"
            android:background="@drawable/bg_chip"
            android:gravity="center_vertical" android:orientation="horizontal"
            android:visibility="gone">

            <View android:id="@+id/motionDot"
                android:layout_width="14dp" android:layout_height="14dp"
                android:background="@drawable/motion_dot"
                android:visibility="gone" />

            <TextView android:id="@+id/motionLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="MOTION" android:textColor="@color/text_dim"
                android:textSize="12sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end" android:layout_margin="12dp"
        android:orientation="horizontal">

        <ToggleButton android:id="@+id/btnFlashlight"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/toggle_text"
            android:textOn="Torch" android:textOff="Torch" />

        <Button android:id="@+id/btnPtt"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="PTT" />

        <Button android:id="@+id/btnSnap"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="📷" />

        <Button android:id="@+id/btnRecord"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="📹" />

        <Button android:id="@+id/btnLens"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Lens" />

        <Button android:id="@+id/btnSnapshots"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Gallery" />

        <Button android:id="@+id/btnSettings"
            style="@style/ControlButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="⚙" />
    </LinearLayout>
</FrameLayout>
