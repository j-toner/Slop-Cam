<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Status: Off" />

        <Switch android:id="@+id/switchService" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Enable Camera Service" />

        <Switch android:id="@+id/switchMotion" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Motion Watch" />

        <Button android:id="@+id/btnSnap" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Take Snapshot" />

        <Button android:id="@+id/btnSettings" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Settings" />

        <Button android:id="@+id/btnDim" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Screen Off (power save)" />
    </LinearLayout>

    <!-- power-save mode: black overlay + zero brightness, tap to wake -->
    <View android:id="@+id/dimOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#000000"
        android:clickable="true" android:focusable="true"
        android:visibility="gone" />
</FrameLayout>
